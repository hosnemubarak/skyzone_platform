# PostgreSQL Database Settings
DB_NAME=skyzone_db
DB_USER=skyzone_user
DB_PASSWORD=super_secure_password_here
DB_PORT=5432
# DB_HOST is set to 'db' automatically by docker-compose, but you can override here

# Django Settings
SECRET_KEY=generate_a_random_secure_secret_key_here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.skyzoneintl.com

# Next.js Frontend Settings
NEXT_PUBLIC_API_URL=https://api.skyzoneintl.com/api

# Mail Server Settings
TZ=Asia/Dhaka
